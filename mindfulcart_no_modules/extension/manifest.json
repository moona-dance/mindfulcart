{
  "manifest_version": 3,
  "name": "MindfulCart",
  "version": "1.0.0",
  "description": "Pause before you purchase. MindfulCart gives you a gentle moment of reflection before checkout.",
  "permissions": ["scripting", "activeTab", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MindfulCart"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
